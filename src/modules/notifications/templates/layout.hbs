<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #333; line-height: 1.6; margin: 0; padding: 0; }
        .container { max-width: 600px; margin: 20px auto; border: 1px solid #e0e0e0; border-radius: 8px; overflow: hidden; }
        .header { background-color: #f8fafc; padding: 20px; text-align: center; border-bottom: 1px solid #e2e8f0; }
        .content { padding: 30px; background-color: #ffffff; }
        .footer { background-color: #f1f5f9; padding: 20px; text-align: center; font-size: 12px; color: #64748b; }
        .logo { max-width: 150px; height: auto; margin-bottom: 10px; }
        .btn { display: inline-block; padding: 12px 24px; background-color: #2563eb; color: #ffffff; text-decoration: none; border-radius: 6px; font-weight: bold; margin-top: 20px; }
        .tag { display: inline-block; padding: 2px 8px; background-color: #e2e8f0; border-radius: 4px; font-size: 11px; font-weight: bold; text-transform: uppercase; margin-bottom: 10px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <img src="cid:logo" alt="bulkmandi" class="logo">
            <div style="font-size: 20px; font-weight: bold; color: #1e293b;">bulkmandi</div>
        </div>
        <div class="content">
            {{{body}}}
        </div>
        <div class="footer">
            &copy; {{year}} bulkmandi Platform. All rights reserved.<br>
            Support: support@bulkmandi.in | +91 99999 99999
        </div>
    </div>
</body>
</html>
